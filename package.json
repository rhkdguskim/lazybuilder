{
  "name": "lazybuilder-cli",
  "version": "0.1.1",
  "description": "TUI + CLI for diagnosing .NET / MSBuild / C++ / CMake build environments and executing builds. Designed as a tool for AI dev loops (Claude Code, Cursor, …) and as a human-friendly TUI.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "rhkdguskim",
    "email": "kwanghyeon.kim@mirero.co.kr"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhkdguskim/lazybuilder.git"
  },
  "homepage": "https://github.com/rhkdguskim/lazybuilder#readme",
  "bugs": {
    "url": "https://github.com/rhkdguskim/lazybuilder/issues"
  },
  "keywords": [
    "tui",
    "cli",
    "build",
    "dotnet",
    "msbuild",
    "cmake",
    "cpp",
    "csharp",
    "ink",
    "react",
    "ai-tool",
    "agent",
    "claude-code",
    "harness"
  ],
  "bin": {
    "lazybuilder": "./bin/lazybuilder.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/main.tsx",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "prepare": "test -d node_modules/typescript && tsc -p tsconfig.json || true",
    "prepublishOnly": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "fast-glob": "^3.3.0",
    "fast-xml-parser": "^4.4.0",
    "figures": "^6.1.0",
    "ink": "^5.2.0",
    "react": "^19.2.5",
    "tree-kill": "^1.2.2",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
